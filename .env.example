# ============================================================
# Forever — Digital Memories | Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your keys.
# NEVER commit .env.local to Git.
# ============================================================

# ── REQUIRED ─────────────────────────────────────────────────
# Claude API key from console.anthropic.com
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── OPTIONAL (ElevenLabs — add when ready) ──────────────────
# REAL_VOICE: Get these from elevenlabs.io after cloning Ammi's voice
# VITE_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# VITE_ELEVENLABS_VOICE_ID=your_cloned_voice_id_here
